server {
    listen 80;
    root /var/www/html/public;
    index {{ getenv "NGINX_INDEX_FILE" "index.php" }};

    # Static assets — long cache
    location ~* \.(?:{{ getenv "NGINX_STATIC_EXT_REGEX" "css|js|jpg|jpeg|png|gif|ico|svg|webp|avif|woff|woff2|ttf|eot|otf" }})$ {
        expires {{ getenv "NGINX_STATIC_EXPIRES" "1y" }};
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # Livewire — streaming preview endpoint
    location = /livewire/preview-file {
        try_files $uri /index.php?$query_string;
    }

    # Livewire — un-hashed base JS: no cache
    location = /livewire/livewire.js {
        add_header Cache-Control "no-store";
        try_files $uri /index.php?$query_string;
    }

    # Livewire — hashed JS: long cache
    location ~ ^/livewire/livewire\.[a-zA-Z0-9]+\.js$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri /index.php?$query_string;
    }

    # Flux assets — served by PHP, always fresh
    location ~* /flux/flux\. {
        add_header Cache-Control "no-store";
        try_files $uri /index.php?$query_string;
    }

    # Main routing
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # PHP-FPM
    location ~ \.php$ {
        fastcgi_pass {{ getenv "NGINX_FASTCGI_PASS" "app-main:9000" }};
        fastcgi_index {{ getenv "NGINX_FASTCGI_INDEX" "index.php" }};
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_param HTTP_PROXY "";
        fastcgi_intercept_errors on;
        fastcgi_request_buffering off;
        fastcgi_read_timeout 600;
    }
}
