# wodby/nginx — Laravel vhost preset.
# Uses wodby's built-in laravel preset (Livewire/Flux/static rules included).
NGINX_VHOST_PRESET=laravel
# Laravel's front controller lives in public/.
NGINX_SERVER_ROOT=/var/www/html/public
# FastCGI upstream — our PHP service is "app-main", not wodby's default "php".
NGINX_BACKEND_HOST=app-main
NGINX_BACKEND_PORT=9000
NGINX_STATIC_EXT_REGEX=css|js|jpg|jpeg|png|gif|ico|svg|webp|avif|woff|woff2|ttf|eot|otf
NGINX_STATIC_EXPIRES=1y
