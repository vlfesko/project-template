#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
PROJECT_ROOT=$(cd -- "$SCRIPT_DIR/.." && pwd)
cd "$PROJECT_ROOT"

if docker compose version > /dev/null 2>&1; then
  DOCKER_COMPOSE=(docker compose)
else
  DOCKER_COMPOSE=(docker-compose)
fi

if [ -f ".env.example" ]; then
  # shellcheck disable=SC1091
  source ".env.example"
fi

if [ -f ".env" ]; then
  # shellcheck disable=SC1091
  source ".env"
fi

COMPOSE_ENV=${COMPOSE_ENV:-local}
COMPOSE_FILES=("compose.yaml")
INCLUDE_DEV=1
INCLUDE_SRC=1

add_compose_file() {
  local file=$1
  if [ -f "$file" ]; then
    COMPOSE_FILES+=("$file")
  fi
}

while [ $# -gt 0 ]; do
  case "$1" in
    --no-dev)
      INCLUDE_DEV=0
      shift
      ;;
    --no-src)
      INCLUDE_SRC=0
      shift
      ;;
    *)
      break
      ;;
  esac
done

add_compose_file "compose.${COMPOSE_ENV}.yaml"
add_compose_file "compose.override.yaml"
add_compose_file "compose.healthcheck.yaml"
if [ "$INCLUDE_SRC" -eq 1 ]; then
  add_compose_file "compose.src.yaml"
fi

if [ "$(uname -sm)" = "Darwin arm64" ]; then
  add_compose_file "compose.${COMPOSE_ENV}.arm64v8.yaml"
  export DOCKER_DEFAULT_PLATFORM="${DOCKER_DEFAULT_PLATFORM:-linux/arm64/v8}"
fi

if [ "$INCLUDE_DEV" -eq 1 ]; then
  add_compose_file "compose.dev.yaml"
fi

COMPOSE_FILES_PREFIXED=()
for file in "${COMPOSE_FILES[@]}"; do
  COMPOSE_FILES_PREFIXED+=("-f" "$file")
done

"${DOCKER_COMPOSE[@]}" "${COMPOSE_FILES_PREFIXED[@]}" "$@"
