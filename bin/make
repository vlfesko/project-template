#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
PROJECT_ROOT=$(cd -- "$SCRIPT_DIR/.." && pwd)
cd "$PROJECT_ROOT"

MAKE_BIN=$(command -v make)
MAKE_ARGS=()
MAKE_VARS=()

for arg in "$@"; do
  case "$arg" in
    --no-src)
      MAKE_VARS+=("NO_SRC=1")
      ;;
    --no-dev)
      MAKE_VARS+=("NO_DEV=1")
      ;;
    *)
      MAKE_ARGS+=("$arg")
      ;;
  esac
done

CMD=("$MAKE_BIN")
[ ${#MAKE_ARGS[@]} -gt 0 ] && CMD+=("${MAKE_ARGS[@]}")
[ ${#MAKE_VARS[@]} -gt 0 ] && CMD+=("${MAKE_VARS[@]}")

exec "${CMD[@]}"
